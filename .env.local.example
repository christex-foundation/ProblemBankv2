# Problem Bank — environment template.
# Copy to .env.local and fill in. Never commit .env.local.

# ---------- NextAuth ----------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ---------- Database (Supabase Postgres) ----------
# DATABASE_URL: pooled connection (port 6543, ends with ?pgbouncer=true)
DATABASE_URL=
# DIRECT_URL: direct connection (port 5432) — used by `prisma migrate`
DIRECT_URL=

# Supabase public/anon (only needed if you call Supabase directly from the client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — never expose
SUPABASE_SERVICE_ROLE_KEY=

# ---------- OAuth ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Cloudinary (files) ----------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=problem_bank_unsigned

# ---------- Cloudflare Turnstile (bot protection) ----------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------- Twilio Verify (phone OTP — Phase 6) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# ---------- Resend (password-reset email only — Phase 6) ----------
RESEND_API_KEY=
EMAIL_FROM=noreply@christex.foundation

# ---------- GitHub API (raises public rate limit; optional) ----------
GITHUB_API_TOKEN=

# ---------- Public base URL (used by badge snippet generator) ----------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
