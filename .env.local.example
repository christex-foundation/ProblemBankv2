# Problem Bank — environment template.
# Copy to .env.local and fill in. Never commit .env.local.
#
# ---------- Local dev quickstart ----------
# Email/password is the only auth provider that works without secrets. To skip
# the signup form, seed a dev user once via the Supabase SQL editor:
#
#   insert into "User" (id, email, name, "passwordHash", role)
#   values (
#     '00000000-0000-0000-0000-000000000001',
#     'dev@local.test',
#     'Dev User',
#     '$2a$10$O0Ha1EODJt9erkV73N1E3eotZslbW0FrnlSRz1utYeVfpO9JP5YGq',
#     'admin'
#   )
#   on conflict (email) do nothing;
#
# Sign in at /signin with: dev@local.test / devpass123
# To regenerate the hash with a different password:
#   node -e "console.log(require('bcryptjs').hashSync('YOURPASS', 10))"

# ---------- NextAuth ----------
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ---------- Supabase (server-only — service-role bypasses RLS) ----------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- OAuth ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- Cloudflare Turnstile (bot protection) ----------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---------- Twilio Verify (phone OTP) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

# ---------- Resend (password-reset email only) ----------
RESEND_API_KEY=
EMAIL_FROM=noreply@christex.foundation

# ---------- GitHub API (raises public rate limit; optional) ----------
GITHUB_API_TOKEN=

# ---------- Public base URL (used by badge snippet generator) ----------
NEXT_PUBLIC_BASE_URL=http://localhost:3000
